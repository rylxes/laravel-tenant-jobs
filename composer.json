{
    "name": "rylxes/laravel-tenant-jobs",
    "description": "Bulletproof multi-tenant queue job handling for Laravel. Fixes context leaking, facade singletons, scheduled dispatch, retry context, batch propagation, and queued notifications across stancl/tenancy and spatie/laravel-multitenancy.",
    "keywords": ["laravel", "multi-tenant", "queue", "jobs", "tenancy", "multitenancy"],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Sherriff Agboola",
            "email": "rylxes@gmail.com"
        }
    ],
    "homepage": "https://github.com/rylxes/laravel-tenant-jobs",
    "support": {
        "issues": "https://github.com/rylxes/laravel-tenant-jobs/issues",
        "source": "https://github.com/rylxes/laravel-tenant-jobs"
    },
    "require": {
        "php": "^8.1",
        "illuminate/bus": "^10.0|^11.0|^12.0",
        "illuminate/queue": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "suggest": {
        "rylxes/laravel-multitenancy": "Recommended: first-class integration with zero-config setup (^1.0)",
        "spatie/laravel-multitenancy": "Required if using the Spatie tenant resolver (^3.0|^4.0)",
        "stancl/tenancy": "Required if using the Stancl tenant resolver (^3.0)"
    },
    "autoload": {
        "psr-4": {
            "TenantJobs\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TenantJobs\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "TenantJobs\\TenantJobsServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage"
    },
    "config": {
        "sort-packages": true
    }
}
